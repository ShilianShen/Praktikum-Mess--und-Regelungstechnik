% =========================================================
% Sprache und Schriften / 语言与字体
% =========================================================
% iftex lets this file react to the compiler:
% - pdfLaTeX: old 8-bit engine, good for plain German/English.
% - XeLaTeX/LuaLaTeX: modern Unicode engines, needed for Chinese text.
% 中文说明：这里根据编译器自动选择字体方案。含中文时建议用 XeLaTeX。
\usepackage{iftex}
\ifPDFTeX
  % T1 improves German hyphenation and accented letters in pdfLaTeX.
  % utf8 allows UTF-8 source files.
  % newtxtext gives a Times-like serif font.
  \usepackage[T1]{fontenc}
  \usepackage[utf8]{inputenc}
  \usepackage{newtxtext}
\else
  % fontspec is the standard font package for XeLaTeX/LuaLaTeX.
  % ctex adds Chinese typesetting support. fontset=fandol uses fonts
  % shipped with TeX Live, so it works without macOS/Windows system fonts.
  \usepackage{fontspec}
  \usepackage[fontset=fandol]{ctex}

  % Main text font: TeX Gyre Termes is similar to Times New Roman.
  % The font is loaded by file name, which is more reliable than system
  % font names when using XeLaTeX in different environments.
  \setmainfont{texgyretermes}[
    Extension=.otf,
    UprightFont=*-regular,
    BoldFont=*-bold,
    ItalicFont=*-italic,
    BoldItalicFont=*-bolditalic
  ]

  % Sans-serif font: TeX Gyre Heros is similar to Arial/Helvetica.
  % Useful for labels, diagrams, and sans-serif text.
  \setsansfont{texgyreheros}[
    Extension=.otf,
    UprightFont=*-regular,
    BoldFont=*-bold,
    ItalicFont=*-italic,
    BoldItalicFont=*-bolditalic
  ]

  % Monospace font for code listings or terminal-style text.
  \setmonofont{lmmonolt10}[
    Extension=.otf,
    UprightFont=*-regular,
    ItalicFont=*-oblique,
    BoldFont=*-bold,
    BoldItalicFont=*-boldoblique
  ]
\fi

% ngerman selects German hyphenation and German names such as "Inhalt".
\usepackage[ngerman]{babel}

% =========================================================
% Seitenlayout / 页面布局
% =========================================================
% geometry controls paper size and margins.
% The uploaded conference-template-a4.docx uses IEEE-like A4 margins:
%   left/right about 44.65 pt = 15.75 mm
%   top about 54 pt = 19.05 mm
%   bottom 72 pt = 25.40 mm
% It also uses a two-column body with about 18 pt = 6.35 mm column gap.
\usepackage[
  a4paper,
  left=15.75mm,
  right=15.75mm,
  top=19.05mm,
  bottom=25.4mm,
  columnsep=6.35mm,
  headheight=12pt,
  headsep=6mm,
  footskip=10mm
]{geometry}

% =========================================================
% Absatz und Zeilenabstand / 段落与行距
% =========================================================
% The Word conference template uses compact 10 pt Times text with about
% 11.4 pt line spacing and first-line indentation. This is different from
% the general Allg.md note about 1.5 line spacing, but Vorgaben.md explicitly
% points to this uploaded conference template.
\usepackage{setspace}
\setstretch{1}

% etoolbox is used below to patch LaTeX's title command.
\usepackage{etoolbox}

% ragged2e provides \justifying. The AtBeginDocument hook applies it after
% all packages and class settings have loaded.
\usepackage{ragged2e}
\AtBeginDocument{%
  \fontsize{10pt}{11.4pt}\selectfont
  \justifying
}

% Template body text: first-line indent around 14.4 pt and only small
% paragraph spacing.
\setlength{\parindent}{14.4pt}
\setlength{\parskip}{0pt}

% Two-column body like the Word template. The title is handled specially
% below so it can still span the full page width.
\AtBeginDocument{\twocolumn}

% =========================================================
% Gemeinsame Titeldaten / 公共标题信息
% =========================================================
% Put information here when it is identical for V1, V2, V3, ...
% Each main.tex then only needs \mrtmetadata{<title>}.
\newcommand{\MRTAuthor}{
  Shilian Shen, 606903\\
  Haotian Zheng\\
  Junhong Zhou\\
  Ximan Hong, 606915\\
  Yingding Cheng
}

% Institution text shown below the authors. Keep it empty if not needed.
\newcommand{\MRTAffiliation}{%
  Institut fuer elektrische Informationstechnik\\
  Technische Universitaet Clausthal
}

% Usage in main.tex:
%   \mrtmetadata{Versuch 1: Elementare Uebertragungsglieder}
% This sets title, author, and date for \maketitle.
\newcommand{\mrtmetadata}[1]{%
  \title{#1}%
  \author{\MRTAuthor}%
  \date{\MRTAffiliation}%
}

% IEEE-like title block. In two-column mode, article.cls can place the title
% across both columns using \twocolumn[...]. We patch \maketitle so main.tex
% can still use the normal command.
\makeatletter
\renewcommand{\@maketitle}{%
  \newpage
  \null
  \vskip -1.5em%
  \begin{center}%
    {\fontsize{24pt}{28pt}\selectfont \@title \par}%
    \vskip 1.0em%
    {\fontsize{11pt}{13pt}\selectfont \@author \par}%
    \vskip 0.6em%
    {\fontsize{9pt}{11pt}\itshape \@date \par}%
  \end{center}%
  \vskip 1.2em%
}
\makeatother

% =========================================================
% Mathematik und Einheiten / 数学与单位
% =========================================================
% amsmath/amssymb/mathtools are the standard packages for equations,
% symbols, aligned formulas, matrices, etc.
\usepackage{amsmath}
\usepackage{amssymb}
\usepackage{mathtools}

% siunitx formats numbers and units consistently:
%   \SI{3.5}{\volt} or \qty{3.5}{\volt}
% locale=DE gives German number formatting conventions.
\usepackage[
  locale=DE,
  separate-uncertainty=true,
  per-mode=symbol
]{siunitx}

\sisetup{
  % German decimal comma: 1,23 instead of 1.23.
  output-decimal-marker={,},
  % Scientific notation product: 1,2 \cdot 10^3.
  exponent-product=\cdot
}

% Common shortcut: \R prints the real numbers symbol.
\newcommand{\R}{\mathbb{R}}

% =========================================================
% Bilder und Tabellen / 图片与表格
% =========================================================
% graphicx provides \includegraphics.
\usepackage{graphicx}

% Search paths for figures. From V1/main.tex, "figures/" means V1/figures;
% "../figures/" means a shared top-level figures folder.
\graphicspath{{figures/}{../figures/}}

% float provides [H] for placing a figure/table exactly "here".
% Use [H] sparingly; normal floats [htbp] often produce nicer pages.
\usepackage{float}

% subcaption supports subfigures, e.g. (a), (b), inside one figure.
\usepackage{subcaption}

% booktabs gives professional table rules: \toprule, \midrule, \bottomrule.
\usepackage{booktabs}

% tabularx helps create tables with automatic-width text columns.
\usepackage{tabularx}

% array extends table column definitions.
\usepackage{array}

% longtable allows tables that continue across page breaks.
\usepackage{longtable}

% caption controls figure/table captions.
% The Word template uses 8 pt captions, figure captions below figures,
% and table headings above tables.
\usepackage[
  font=footnotesize,
  labelfont=bf,
  justification=justified,
  singlelinecheck=false
]{caption}

% LaTeX places figure/table captions wherever \caption is written.
% Convention: put \caption below figures and above tables in main.tex.
\captionsetup{skip=4pt}

% =========================================================
% Listen / 列表
% =========================================================
% enumitem gives control over list spacing. The settings below keep lists
% compact, which matters in short reports with a page limit.
\usepackage{enumitem}
\setlist[itemize]{
  topsep=0.4em,
  itemsep=0.2em,
  parsep=0pt
}
\setlist[enumerate]{
  topsep=0.4em,
  itemsep=0.2em,
  parsep=0pt
}

% =========================================================
% Ueberschriften / 标题层级
% =========================================================
% titlesec lets us make LaTeX headings closer to the Word template:
% - section: centered, small caps, compact spacing
% - subsection: left aligned, italic, compact spacing
\usepackage{titlesec}
\titleformat{\section}
  {\normalfont\normalsize\scshape\centering}
  {\thesection}
  {0.8em}
  {}
\titlespacing*{\section}{0pt}{8pt}{4pt}

\titleformat{\subsection}
  {\normalfont\normalsize\itshape}
  {\thesubsection}
  {0.8em}
  {}
\titlespacing*{\subsection}{0pt}{6pt}{3pt}

\titleformat{\subsubsection}
  {\normalfont\normalsize\itshape}
  {\thesubsubsection}
  {0.8em}
  {}
\titlespacing*{\subsubsection}{\parindent}{2pt}{2pt}

% =========================================================
% Nummerierung / 编号
% =========================================================
% The Word conference template numbers figures, tables and equations
% consecutively through the whole document, e.g. Fig. 1, Table I, (1).
% Therefore we do not reset these counters by section.

% =========================================================
% Kopf- und Fusszeile / 页眉页脚
% =========================================================
% The uploaded conference template has a very light header/footer style.
% For the lab report we keep only the page number in the footer.
\usepackage{fancyhdr}
\pagestyle{fancy}

% Clear all default header/footer fields before setting our own.
\fancyhf{}

\fancyfoot[C]{\thepage}

% No visible header rule in the conference style.
\renewcommand{\headrulewidth}{0pt}

% =========================================================
% Querverweise und Links / 交叉引用与链接
% =========================================================
% hyperref creates clickable links in the PDF.
% It should usually be loaded late because it patches many LaTeX commands.
\usepackage[
  unicode,
  hidelinks,
  bookmarksopen=true,
  bookmarksnumbered=true
]{hyperref}

% cleveref improves references:
%   \cref{fig:test} -> "Abbildung 1.1"
% nameinlink makes the whole reference text clickable.
\usepackage[
  german,
  nameinlink,
  noabbrev
]{cleveref}

% =========================================================
% Literatur / 参考文献
% =========================================================
% csquotes is recommended with biblatex, especially for German documents.
\usepackage{csquotes}

% biblatex manages citations and the bibliography.
% backend=biber means LaTeX Workshop/latexmk will run biber automatically.
% style=numeric gives citations like [1].
% sorting=none keeps bibliography entries in citation order.
\usepackage[
  backend=biber,
  style=numeric,
  sorting=none,
  giveninits=true
]{biblatex}

% Use a bibliography file if it exists.
% The first path is for a .bib next to main.tex, the second for a shared
% .bib one directory above.
\IfFileExists{literatur.bib}{\addbibresource{literatur.bib}}{}
\IfFileExists{../literatur.bib}{\addbibresource{../literatur.bib}}{}

% =========================================================
% Quellcode / 代码清单
% =========================================================
% listings formats source code blocks. Useful if Matlab/Python snippets
% need to appear in the report.
\usepackage{listings}
\lstset{
  % Monospace, small text.
  basicstyle=\ttfamily\small,
  % Line numbers on the left.
  numbers=left,
  numberstyle=\tiny,
  % Simple box around code.
  frame=single,
  % Wrap long code lines instead of letting them run into the margin.
  breaklines=true,
  columns=fullflexible,
  % Do not show spaces inside strings with special symbols.
  showstringspaces=false
}
